@model ResortBookingUI.MVC.Models.Resort

<h2>Create Resort</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form method="post">
    <input asp-for="ResortName" class="form-control mb-2" placeholder="Name" />
    <input asp-for="ResortLocation" class="form-control mb-2" placeholder="Location" />
    <input asp-for="ResortImageUrl" class="form-control mb-2" placeholder="Image URL" />
    <input asp-for="Price" class="form-control mb-2" placeholder="Price" />
    <input asp-for="Capacity" class="form-control mb-2" placeholder="Capacity" />
    <input asp-for="Description" class="form-control mb-2" placeholder="Description" />
    <select asp-for="ResortAvailableStatus" class="form-control mb-2">
        <option value="">-- Select Status --</option>
        <option value="Available">Available</option>
        <option value="Full">Full</option>
    </select>

    <button class="btn btn-success">Save</button>
    <a class="btn btn-secondary" asp-action="Index">Back</a>
</form>