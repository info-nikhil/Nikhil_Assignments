@model ResortBookingUI.MVC.Models.Resort

<h2>@Model.ResortName</h2>

<img src="@Model.ResortImageUrl" class="img-fluid mb-3" style="max-height:300px;" />

<div class="card p-3">
    <p><b>Location:</b> @Model.ResortLocation</p>
    <p><b>Price:</b> ₹@Model.Price</p>
    <p><b>Capacity:</b> @Model.Capacity</p>
    <p><b>Description:</b> @Model.Description</p>
</div>

<a class="btn btn-secondary mt-3" asp-action="Index">Back</a>