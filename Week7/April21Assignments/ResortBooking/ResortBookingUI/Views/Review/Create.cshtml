@model ResortBookingUI.MVC.Models.Review

<h2>Add Review</h2>

<form method="post">

    <input asp-for="Subject" class="form-control mb-2" placeholder="Subject" />

    <textarea asp-for="Body" class="form-control mb-2" placeholder="Write review"></textarea>

    <input asp-for="Rating" class="form-control mb-2" placeholder="Rating (1-5)" />

    <button class="btn btn-success">Submit</button>
    <a class="btn btn-secondary" asp-action="Index">Back</a>

</form>